root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h}]
indent_style = space
indent_size = 4

[meson.build]
indent_style = space
indent_size = 2

[*.{md,toml}]
indent_style = space
indent_size = 2

[*.{desktop,pc,pc.in}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
